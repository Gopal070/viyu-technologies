# Server
PORT=5000

# MongoDB – use local or Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/viyu_technologies

# JWT secret (change this to a long random string in production)
JWT_SECRET=change_this_to_a_random_secret_key_123

# Default admin credentials (used by seed script)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=info@viyutech.in

# Email configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
